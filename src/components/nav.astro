---
import { Icon } from 'astro-icon/components';
import ThemeToggle from './theme-toggle.astro';
interface NavItem {
  label: string;
  href: string;
  icon: string;
}

const navItems: NavItem[] = [
  {
    label: "Home",
    href: "#home",
    icon: `mdi:home`,
  },
  {
    label: "Career",
    href: "#career",
    icon: `mdi:work`,
  },
  {
    label: "Projects",
    href: "#projects",
    icon: `mdi:computer`,
  },
  {
    label: "Tech",
    href: "#tech",
    icon: `mdi:code-tags`,
  },
  // {
  //   label: "Education",
  //   href: "#contact",
  //   icon: `mdi:message`,
  // },
  {
    label: "Contact",
    href: "#contact",
    icon: `mdi:message`,
  }
];
---
<div id="theme-toggle-wrapper" class="fixed top-4 right-4 z-50 md:top-4 md:right-4 reveal-content" style="animation-delay: 700ms;">
  <ThemeToggle />
</div>

<div class="flex justify-center w-full">
  <nav
    id="main-nav"
    class="fixed left-1/2 -translate-x-1/2 z-20 border-[1.2px] border-transparent transition-all duration-500 ease-in-out md:top-6 md:bottom-auto bottom-0 w-[80%]"
  >
    <div class="container mx-auto flex justify-center items-center p-3 reveal-content" style="animation-delay: 700ms;">
      <ul
        class="flex w-full justify-between md:space-x-6 md:justify-center md:gap-12 gap-1"
      >
        {
          navItems.map((item) => (
            <li class="flex-1 md:flex-none">
              <a
                href={item.href}
                class="flex flex-col items-center gap-1 text-accent transition-colors text-xs md:text-base relative group"
              >
                <div class="absolute -left-6 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full transition-all duration-300 scale-0 opacity-0 nav-indicator hidden md:block" />
                <span class="md:hidden flex items-center justify-center w-6 h-6">
                  <Icon 
                    name={item.icon} 
                    class="nav-icon w-full h-full text-accent/50 group-hover:text-accent transition-colors duration-300" 
                  />
                </span>
                <span class="hidden md:inline-block">{item.label}</span>
                <span class="md:hidden text-xs">{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</div>

<style>
    /* Reveal whole section when website loads */
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  nav {
    background-color: transparent;
    border-color: transparent;
    backdrop-filter: blur(0px);
    transition:
      background-color 0.4s ease,
      backdrop-filter 0.4s ease,
      border-radius 0.4s ease,
      border-color 0.4s ease,
      width 0.4s ease;
  }

   nav.scrolling {
    background-color: color-mix(in srgb, var(--color-background), transparent 75%);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    
    border-radius: 9999px;
    backdrop-filter: blur(10px);
  }

  nav a.active .nav-indicator {
    transform: translateY(-50%) scale(1);
    opacity: 0;
  }

  /* Base state for the link text */
  nav a {
    transition: transform 0.3s ease, color 0.3s ease, font-weight 0.3s ease;
  }

  /* Active state */
  nav a.active {
    color: var(--color-maintext) !important;
    font-weight: 700;
    transform: scale(1.1);
  }

  /* Glow effect */
  nav a.active span {
    text-shadow: 0 0 10px color-mix(in srgb, var(--color-maintext) 30%, transparent);
  }

  /* Ensure the scale doesn't jitter the layout */
  nav li {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Icon style for mobile view */
  .nav-icon {
    transition: transform 0.3s ease, color 0.3s ease, filter 0.3s ease;
  }

  nav a.active .nav-icon {
    color: var(--color-maintext) !important;
    transform: scale(1.2);
    filter: drop-shadow(0 0 8px var(--color-maintext));
  }

  @media (max-width: 767px) {
    nav {
      width: 100% !important;
      bottom: 0;
      border-radius: 1.5rem 1.5rem 0 0;
      background-color: color-mix(in srgb, var(--color-background), transparent 10%);
      backdrop-filter: blur(10px);
      border-top: 1px solid color-mix(in srgb, var(--color-maintext) 15%, transparent);
    }

    nav.scrolling {
      border-radius: 1.5rem 1.5rem 0 0;
      width: 100% !important;
    }

    /* Hiding bottom bar while scroling on mobile */
    #main-nav {
      /* Force Hardware Acceleration (Fixes the white flash) */
      will-change: transform;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      /* Force it into its own GPU layer permanently */
      transform: translateZ(0);
      -webkit-transform: translateZ(0);
      
      /* Smooth transition */
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important;

      /* Ensure no default background is fighting the blur */
      background-clip: padding-box;
    }

    #main-nav.nav-hidden {
      /* transform: translateY(110%) !important; */
      transform: translate3d(0, 110%, 0) !important;
      
      /* Optional: Turn off blur when hidden to save GPU cycles */
      backdrop-filter: blur(0px);
    }

    /* Hiding theme-toggle while scroling on mobile */
    #theme-toggle-wrapper {
      will-change: transform;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    /* Slide the button UP out of view */
    #theme-toggle-wrapper.theme-hidden {
      transform: translateY(-150%) !important;
    }
  }

  /* Hover effect */
  nav a:not(.active):hover {
    color: var(--color-maintext) !important;
  }

  nav a:not(.active):hover span {
    transform: scale(0.95);
    text-shadow: 0 0 15px var(--color-accent-60);
  }
  
  nav a:not(.active):hover .nav-icon {
    transform: scale(0.95);
    color: var(--color-maintext) !important;
  }

  @media (max-width: 767px) {
    body {
      padding-bottom: 70px;
    }
  }
</style>

<script>
  //scroll morphing effect, changing width & border radius
  const nav = document.getElementById("main-nav");
  const themeWrapper = document.getElementById("theme-toggle-wrapper");

  const maxScroll = 1000;
  let lastScrollY = window.scrollY;
  let rafId: number | null = null;

  function updateNav() {
    const currentScrollY = window.scrollY;

    if (currentScrollY > 0) {
      nav?.classList.add("scrolling");

      const scrollProgress = Math.min(window.scrollY / maxScroll, 1);
      const easeProgress = 1 - Math.pow(1 - scrollProgress, 4);

      const minWidth = 620;
      const maxWidth = window.innerWidth * 0.8;
      const currentWidth = maxWidth - (maxWidth - minWidth) * easeProgress;

      if (window.innerWidth >= 768) {
        nav?.style.setProperty("width", `${currentWidth}px`);
      }
    } else {
      nav?.classList.remove("scrolling");
      // nav?.style.setProperty("width", "80%");
    }
    if (window.innerWidth < 768) {
      // Small buffer (e.g. 10px) to prevent accidental hiding on "jittery" scrolls
      if (currentScrollY > lastScrollY && currentScrollY > 50) {
        // Scrolling Down - Hide Nav & theme-toggle
        nav?.classList.add("nav-hidden");
        themeWrapper?.classList.add("theme-hidden");
      } else {
        // Scrolling Up - Show Nav & theme-toggle
        nav?.classList.remove("nav-hidden");
        themeWrapper?.classList.remove("theme-hidden");
      }
    }

    lastScrollY = currentScrollY;
    rafId = null;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (!rafId) {
        rafId = requestAnimationFrame(updateNav);
      }
    },
    { passive: true }
  );

  //smooth scrolling to a linked section
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", function (e) {
      e.preventDefault();
      const target = e.currentTarget as HTMLAnchorElement;
      const targetId = target.getAttribute("href")?.substring(1) || "";
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        targetElement.scrollIntoView({
          behavior: "smooth",
        });
      }
    });
  });

  //highlight section by observing visible one on the screen by 50%
  document.addEventListener("DOMContentLoaded", () => {
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll("nav a[href^='#']");
    const observerOptions = { threshold: 0.5 };

    const observerCallback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => link.classList.remove("active"));
          const id = entry.target.getAttribute("id");
          const activeLink = document.querySelector(`nav a[href="#${id}"]`);
          if (activeLink) {
            activeLink.classList.add("active");
          }
        }
      });
    };

    const observer = new IntersectionObserver(
      observerCallback,
      observerOptions
    );
    sections.forEach((section) => observer.observe(section));
  });
</script>

